{
  "name": "snoo-flow",
  "version": "0.1.0",
  "type": "module",
  "description": "Close the learning loop — make snoo-flow learn from its own experience",
  "scripts": {
    "build": "tsc",
    "test": "tsx --test tests/*.test.js",
    "lint": "tsc --noEmit",
    "research": "node scripts/research-query.js",
    "snoo": "tsx scripts/run.ts",
    "embed-server:start": "setsid tsx scripts/embed-server.ts >> .swarm/embed-server.log 2>&1 &",
    "embed-server:stop": "if [ -f .swarm/embed.pid ]; then kill \"$(cat .swarm/embed.pid)\" 2>/dev/null; rm -f .swarm/embed.pid; fi; rm -f .swarm/embed.sock",
    "postinstall": "npm run embed-server:stop 2>/dev/null || true"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.10.0",
    "ulid": "^3.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
